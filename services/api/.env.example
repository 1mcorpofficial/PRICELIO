PORT=3000
NODE_ENV=production
PGHOST=localhost
PGPORT=5432
PGUSER=receiptradar
PGPASSWORD=CHANGEME_STRONG
PGDATABASE=receiptradar
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RABBITMQ_URL=amqp://receiptradar:CHANGE_ME@localhost:5672
RECEIPT_QUEUE=receipt_jobs

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security / CORS
CORS_ALLOWLIST=https://pricelio.app,https://www.pricelio.app,http://localhost:8000,http://localhost:3000
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CSRF_COOKIE_NAME=pricelio_csrf_token
REFRESH_COOKIE_NAME=refresh_token

# Admin / ops
ADMIN_API_KEY=
INGEST_SERVICE_URL=http://localhost:3002
INTERNAL_CACHE_BUMP_TOKEN=

# Rate limiting
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_MAX=200
RATE_LIMIT_RECEIPTS_MAX=16
RATE_LIMIT_COMPARE_IP_MAX=45
RATE_LIMIT_COMPARE_USER_MAX=90

# Optional external delivery endpoint for alert notifications
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_MS=5000

# Feature flags
FEATURE_FLAGS_ENFORCE=false
